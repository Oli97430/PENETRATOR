# PENETRATOR Environment Configuration
# Copy this file to .env and customize the values.

# --- API Server ---
# API authentication key (REQUIRED in production — never use the default)
PENETRATOR_API_KEY=changeme

# --- Database ---
# SQLite database path (default: data/penetrator.db)
# PENETRATOR_DB_PATH=data/penetrator.db

# --- Server ---
# Uvicorn host and port (passed via command line, not env vars)
# uvicorn penetrator_api:app --host 0.0.0.0 --port 8000

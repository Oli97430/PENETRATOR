# PENETRATOR Environment Configuration
# Copy this file to .env and customize the values.

# --- API Server ---
# API authentication key (REQUIRED in production — never use the default)
PENETRATOR_API_KEY=changeme

# --- Database ---
# SQLite database path (default: data/penetrator.db)
# PENETRATOR_DB_PATH=data/penetrator.db

# --- Rate Limiting ---
# Max requests per minute per IP (default: 60)
# PENETRATOR_RATE_LIMIT=60

# --- Engine Tuning ---
# HTTP request timeout in seconds (default: 10)
# PENETRATOR_TIMEOUT=10

# TLS certificate verification (1=verify, 0=skip for self-signed targets)
# PENETRATOR_TLS_VERIFY=1

# Max HTTP retry attempts on transient errors (default: 2)
# PENETRATOR_MAX_RETRIES=2

# --- Security ---
# SSRF protection: block scans targeting internal IPs (1=enabled, 0=disabled)
# PENETRATOR_SSRF_PROTECTION=1

# --- CORS (for dashboard/frontend integration) ---
# Comma-separated allowed origins (empty = CORS disabled)
# PENETRATOR_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Server ---
# Uvicorn host and port (passed via command line, not env vars)
# uvicorn penetrator_api:app --host 0.0.0.0 --port 8000
